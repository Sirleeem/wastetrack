# =============================================================================
# WasteTrack — environment template
# Copy to .env and fill in values before deploying.
#   copy .env.example .env          (Windows)
#   cp .env.example .env            (Linux/macOS)
# =============================================================================

# development | production
FLASK_ENV=production

# REQUIRED in production — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Database
# SQLite (default, good for small demos):
# DATABASE_URL=sqlite:///C:/path/to/instance/waste_management.db
# PostgreSQL (recommended for multi-user production):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/wastetrack
DATABASE_URL=

# Bootstrap first admin when DB is empty (production without SEED_DEMO_DATA)
ADMIN_NAME=System Administrator
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change-this-strong-password

# Demo seed (never enable on public production)
SEED_DEMO_DATA=false
SHOW_DEMO_CREDENTIALS=false

# Network
HOST=0.0.0.0
PORT=8000
BEHIND_PROXY=true
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=true

# Uploads (optional absolute path; default: app/static/uploads)
# UPLOAD_FOLDER=/var/lib/wastetrack/uploads
MAX_CONTENT_LENGTH=5242880

# Workers (Gunicorn)
WEB_CONCURRENCY=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=60
LOG_LEVEL=info
