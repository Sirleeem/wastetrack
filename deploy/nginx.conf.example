# Example reverse proxy for WasteTrack behind Nginx (HTTPS recommended).
# Place under /etc/nginx/sites-available/wastetrack and enable the site.
#
# Upstream: Gunicorn/Waitress listening on 127.0.0.1:8000

upstream wastetrack_app {
    server 127.0.0.1:8000 fail_timeout=0;
}

server {
    listen 80;
    server_name waste.example.com;

    # Redirect HTTP -> HTTPS (after certificates are installed)
    # return 301 https://$host$request_uri;

    client_max_body_size 6M;

    location / {
        proxy_pass http://wastetrack_app;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_redirect off;
        proxy_read_timeout 60s;
    }

    location /static/ {
        # Optional: serve static files directly from the project for better performance
        # alias /opt/wastetrack/app/static/;
        # expires 7d;
        # access_log off;
        proxy_pass http://wastetrack_app;
        proxy_set_header Host $host;
    }
}

# TLS example (Certbot):
# server {
#     listen 443 ssl http2;
#     server_name waste.example.com;
#     ssl_certificate     /etc/letsencrypt/live/waste.example.com/fullchain.pem;
#     ssl_certificate_key /etc/letsencrypt/live/waste.example.com/privkey.pem;
#     ... same location blocks as above with X-Forwarded-Proto https ...
# }
